using System;
using System.Collections.Generic;

public class UsersHolderSingleton : LoggerProvider
{
    private static string TAG = "ClassTag";
    private List<UserData> users; // Добавляем кеширование списка пользователей

// ---------------- Const ----------------
    public static class Const
    {
        public const int INDEX = 0; // Индексация начинается с 0
    }

// ---------------- UserData ----------------
public class UserData 
{
        public int id;
        public string name;
        public string phoneNumber;

        //объявление переменных
        public UserData(int id, string name, string phoneNumber)
        {
            this.id = id;
            this.name = name;
            this.phoneNumber = phoneNumber;
        }

        //Для удобства, производить вывод данных пользователя, если это необходимо
       // public override string ToString() => $"ID: {id}, Name: {name}, Phone: {phoneNumber}";
}



// ---------------- Repository ----------------
    public interface IRepository // некорректное название интерфейса (Repository)
    {
        List<UserData> Get();
    }

// ---------------- Singleton ----------------
private static volatile UsersHolderSingleton instance;
private Repository usersRepo; //IRepository
private UsersHolderSingleton(IRepository usersRepo)
    {
        this.usersRepo = usersRepo;
        this.users = usersRepo.Get(); // иницализация кеша пользователей
    }
public static UsersHolderSingleton GetInstance(IRepository usersRepo)
    {
        if (instance == null)
        {
            instance = new UsersHolderSingleton(usersRepo);
        }
        return instance;
    }
public List<UserData> GetUsers()
    {
        return users; 
    }
public void Update(int id, string newPhone)
    {
        string formattedPhone = string.Format("Телефон: {0}", newPhone);
        for (int i = Const.INDEX; i < users.Count; i++)
                {
                    if (users()[i].id == id) 
                    {
                        //Производим обновление данных без создания нового элемента
                        users[i].phoneNumber = formattedPhone;
                        logger?.Tag(TAG)?.D(users[i].ToString()); 
                        break; 
                    }
                }
    }
}

